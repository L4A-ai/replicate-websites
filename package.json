{
  "name": "pixel-by-pixel-skill-repository",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "GitHub distribution and clean-slate evaluation harness for the Pixel by Pixel Agent Skill.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/L4A-ai/replicate-websites.git"
  },
  "homepage": "https://github.com/L4A-ai/replicate-websites#readme",
  "bugs": {
    "url": "https://github.com/L4A-ai/replicate-websites/issues"
  },
  "keywords": [
    "agent-skill",
    "playwright",
    "pixel-diff",
    "website-replication"
  ],
  "workspaces": [
    "skills/pixel-by-pixel"
  ],
  "scripts": {
    "test": "node --test test/skill/*.test.mjs",
    "test:evaluator": "node --test evals/tests/*.test.mjs",
    "check:skill": "node evals/scripts/validate-skill.mjs",
    "check:install": "node evals/scripts/check-portable-install.mjs",
    "check:contamination": "node evals/scripts/check-contamination.mjs",
    "validate": "npm run check:skill && npm run test && npm run test:evaluator && npm run check:contamination"
  },
  "engines": {
    "node": ">=20"
  }
}
